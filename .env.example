# DeepWiki 环境变量示例
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env        （Linux/macOS）
#   copy .env.example .env      （Windows）
#
# 注意：.env 文件包含敏感信息，切勿提交到版本库。

# =============================================================================
# LLM API 密钥（至少填一个，取决于使用的 provider）
# =============================================================================

# OpenAI / OpenAI 兼容接口（最常用）
OPENAI_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# OpenRouter（聚合多个 LLM 提供商）
OPENROUTER_API_KEY=

# 阿里云 DashScope（通义千问等）
DASHSCOPE_API_KEY=

# AWS Bedrock（Claude、Llama 等）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
# 可选：使用 IAM Role 代替 Access Key
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/DeepWikiRole

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# =============================================================================
# 内网自定义 LLM（OpenAI 兼容接口）
# =============================================================================
# 如果使用内网部署的 LLM（如 vLLM、LM Studio、Ollama 等），配置以下变量

# 自定义 LLM（用于 Wiki 生成）
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=

# 自定义 Embedder（用于向量检索，可与 LLM 不同）
CUSTOM_EMBEDDER_BASE_URL=
CUSTOM_EMBEDDER_API_KEY=
CUSTOM_EMBEDDER_MODEL=

# =============================================================================
# 服务配置
# =============================================================================

# 后端监听端口（默认 8001）
PORT=8001

# 前端监听端口（默认 3000，由启动脚本使用）
FRONTEND_PORT=3000

# Node.js 运行环境（生产环境设为 production）
NODE_ENV=production

# 前端访问后端的地址（Next.js 反向代理目标）
# 同机部署保持默认；前后端分开部署时修改为后端 IP/域名
SERVER_BASE_URL=http://localhost:8001

# 日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# 日志文件路径（留空则仅输出到控制台）
LOG_FILE_PATH=api/logs/application.log

# =============================================================================
# Embedding 配置
# =============================================================================

# Embedding 类型：openai / google / ollama / bedrock / custom
DEEPWIKI_EMBEDDER_TYPE=openai

# =============================================================================
# SSL 证书（内网自签名证书场景）
# =============================================================================
# 如果内网 LLM 或 Git 服务使用自签名证书，设置以下变量指向证书捆绑包

# Python SSL / requests / httpx 使用的证书包路径
# SSL_CERT_FILE=C:\certs\internal-ca.crt
# REQUESTS_CA_BUNDLE=C:\certs\internal-ca.crt

# Git 使用的 CA 证书
# GIT_SSL_CAINFO=C:\certs\internal-ca.crt

# 临时跳过 Git SSL 验证（仅用于排查，生产环境不要开启）
# GIT_SSL_NO_VERIFY=true

# =============================================================================
# tiktoken 离线缓存（无法访问 cdn.openai.com 的内网环境）
# =============================================================================
# 预先下载编码文件后设置此变量
# Windows 示例：TIKTOKEN_CACHE_DIR=C:\Users\<用户名>\.tiktoken
# Linux 示例：TIKTOKEN_CACHE_DIR=/home/<用户名>/.tiktoken
# TIKTOKEN_CACHE_DIR=

# =============================================================================
# 访问认证（可选）
# =============================================================================

# 启用访问码认证（true / false）
DEEPWIKI_AUTH_MODE=false

# 访问码（AUTH_MODE=true 时必填）
# DEEPWIKI_AUTH_CODE=your-secret-code

# =============================================================================
# 高级配置
# =============================================================================

# 自定义配置目录（覆盖 api/config/ 中的 JSON 配置）
# 用于自定义可用 LLM 模型列表、提示词模板等
# DEEPWIKI_CONFIG_DIR=/path/to/custom-config
